generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id             String    @id @default(cuid())
  name           String
  whatsapp       String
  serviceType    String
  shootingType   String
  purposes       String
  idea           String?
  referenceLinks String?
  bookingDate    String?
  budget         String?
  needsHelp      Boolean   @default(false)
  status         String    @default("nouveau")
  proposalText   String?
  proposalPrice  String?
  proposalDate   DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model PortfolioPhoto {
  id          String   @id @default(cuid())
  title       String?
  description String?
  category    String   @default("studio")
  imageUrl    String
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
